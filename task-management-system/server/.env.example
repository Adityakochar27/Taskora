# --- Core ---
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/taskflow

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
ADMIN_SIGNUP_KEY=change_me_only_used_for_first_admin

# --- Firebase Cloud Messaging ---
# Single-line JSON of a service-account key file
FIREBASE_SERVICE_ACCOUNT=

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional — pin the exact URL Twilio is configured to call.
TWILIO_WEBHOOK_URL=
TWILIO_VALIDATE_WEBHOOK=false

# --- Misc ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=52428800
LOG_LEVEL=info

# --- Cloudinary (file storage) ---
# Get these from https://cloudinary.com/console (free tier).
# If left blank, attachments save to local disk — but Render's disk is
# ephemeral, so files vanish on every redeploy. Set these for production.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
