# --- Core ---
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/taskflow

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
ADMIN_SIGNUP_KEY=change_me_only_used_for_first_admin

# --- Firebase Cloud Messaging ---
# Single-line JSON of a service-account key file
FIREBASE_SERVICE_ACCOUNT=

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional — pin the exact URL Twilio is configured to call. Useful when
# behind a proxy whose forwarded headers can't be trusted.
TWILIO_WEBHOOK_URL=
# Set TWILIO_VALIDATE_WEBHOOK=true in production to enforce inbound signature
# verification. TWILIO_WEBHOOK_URL must match the public URL Twilio calls.
TWILIO_VALIDATE_WEBHOOK=false
TWILIO_WEBHOOK_URL=

# --- Misc ---
UPLOAD_DIR=./uploads
LOG_LEVEL=info
